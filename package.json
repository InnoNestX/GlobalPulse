{
  "name": "globalpulse",
  "version": "0.1.0",
  "description": "A Cloudflare Workers admin UI and scheduler for finance and global hotspot briefings pushed to Feishu and WeChat.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run typecheck && npm run test"
  },
  "keywords": [
    "cloudflare-workers",
    "scheduled-briefings",
    "finance",
    "global-news",
    "feishu",
    "wechat",
    "wechat-official-account",
    "wechat-ai-agent"
  ],
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "wrangler": "^4.90.1"
  }
}
